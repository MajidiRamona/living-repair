generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

model Submission {
  id     String           @id @default(cuid())
  status SubmissionStatus @default(PENDING)

  // 1. Basic information
  name        String
  tagline     String
  description String

  // 2. What do you repair/transform/upcycle
  repairCategories          Json
  repairCategoriesOtherText String?

  // 3. Who are you
  orgTypes          Json
  orgTypesOtherText String?

  // 4. People
  peopleInvolved String?

  // 5. Activities
  activities          Json
  activitiesOtherText String?

  // 6. Knowledge and skills
  knowledgeSkills String?

  // 7. Challenges and threats (submitter-controlled visibility)
  challengesAndThreats      String?
  challengesPublicRequested Boolean @default(false)

  // Current needs (submitter-controlled visibility)
  needs                Json?
  needsOtherText       String?
  needsPublicRequested Boolean @default(false)

  // Contact
  website     String?
  email       String?
  socialMedia String?

  // Location
  street  String?
  city    String
  region  String?
  country String
  lat     Float?
  lng     Float?

  // Audience
  audience Json

  // Optional heritage-dimension question
  heritageDimension String?

  // Photo upload
  photoPath String?

  // Video link (YouTube, Vimeo, Instagram, etc.)
  videoUrl String?

  // Review / moderation metadata
  rejectionReason String?
  adminNotes      String?
  reviewedAt      DateTime?

  initiative Initiative?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model Initiative {
  id   String @id @default(cuid())
  slug String @unique

  name        String
  tagline     String
  description String

  city    String
  region  String?
  street  String?
  country String
  lat     Float
  lng     Float

  domain       String // legacy marker-color vocabulary
  repairSector String // textile | furniture | electronics | other

  repairCategories Json
  orgTypes         Json
  activities       Json
  audience         Json

  peopleInvolved    String?
  knowledgeSkills   String?
  heritageDimension String?

  challengesAndThreats String?
  challengesPublic     Boolean @default(false)

  needs       Json?
  needsPublic Boolean @default(false)

  // Admin-curated impact metrics (not collected by the public form)
  founded             Int?
  peopleReached       Int?
  itemsRepaired       Int?
  co2SavedT           Float?
  materialsDivertedKg Float?
  socialCohesionScore Int?
  sdgAlignment        Json    @default("[]")
  keywords            Json    @default("[]")
  climateLink         String?

  website     String?
  email       String?
  emailPublic Boolean @default(false)
  socialMedia String?

  photoPath String?
  videoUrl  String?
  featured  Boolean @default(false)
  published Boolean @default(true)

  hiddenFields Json? // string[] — generic admin "hide this field" escape hatch

  submission   Submission? @relation(fields: [submissionId], references: [id])
  submissionId String?     @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published])
  @@index([repairSector])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

// Governs whether — and how much of — a submission can ever be published.
// This is the submitter's choice; the admin panel can only narrow it further
// (e.g. hide additional fields), never override it to publish more than consented.
enum PublicationConsent {
  YES                   // full publish allowed, including challenges/threats
  YES_EXCEPT_CHALLENGES // publish allowed, but challenges & threats must stay private
  NO                    // store only — can never be published as a public initiative
}

model Submission {
  id     String           @id @default(cuid())
  status SubmissionStatus @default(PENDING)

  // 1. Basic information
  name        String? // optional — not everyone has a formal entity/initiative name
  tagline     String
  description String

  // 2. Activities
  activities          Json
  activitiesOtherText String?

  // 3. What do you repair/transform/upcycle
  repairCategories          Json
  repairCategoriesOtherText String?

  // 4. Who are you
  orgTypes          Json
  orgTypesOtherText String?

  // 5. People
  peopleInvolved String?

  // 6. Knowledge and skills
  knowledgeSkills String?

  // 7. Why do you care about repair / heritage transmission (moved ahead of challenges)
  heritageDimension String?

  // 8. Challenges and threats
  challengesAndThreats String?

  // 9. Current needs
  needs          Json?
  needsOtherText String?

  // 10. Contact — name and email are mandatory and never published, regardless of consent
  contactName String
  email       String
  website     String?
  socialMedia String?

  // 11. Location
  street  String?
  city    String
  region  String?
  country String
  lat     Float?
  lng     Float?

  // 12. Audience
  audience Json

  // Photo / video
  photoPath String?
  videoUrl  String?

  // Publication consent — the ceiling on what admin approval can ever expose
  publicationConsent PublicationConsent @default(NO)

  // Review / moderation metadata
  rejectionReason String?
  adminNotes      String?
  reviewedAt      DateTime?

  initiative Initiative?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model Initiative {
  id   String @id @default(cuid())
  slug String @unique

  name        String
  tagline     String
  description String

  city    String
  region  String?
  street  String?
  country String
  lat     Float
  lng     Float

  domain       String // legacy marker-color vocabulary
  repairSector String // textile | furniture | electronics | other

  repairCategories Json
  orgTypes         Json
  activities       Json
  audience         Json

  peopleInvolved    String?
  knowledgeSkills   String?
  heritageDimension String?

  challengesAndThreats String?
  challengesPublic     Boolean @default(false)

  needs Json?

  // Admin-curated impact metrics (not collected by the public form)
  founded             Int?
  peopleReached       Int?
  itemsRepaired       Int?
  co2SavedT           Float?
  materialsDivertedKg Float?
  socialCohesionScore Int?
  sdgAlignment        Json    @default("[]")
  keywords            Json    @default("[]")

  // Note: no email/contact-name fields here at all — contact info from the submission
  // is never copied onto a public Initiative, so there's nothing here that could leak it.
  website     String?
  socialMedia String?

  photoPath String?
  videoUrl  String?
  featured  Boolean @default(false)
  published Boolean @default(true)

  hiddenFields Json? // string[] — generic admin "hide this field" escape hatch

  submission   Submission? @relation(fields: [submissionId], references: [id])
  submissionId String?     @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published])
  @@index([repairSector])
}
